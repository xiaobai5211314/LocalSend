# ============================================================================
# LocalSend 服务器环境变量模板
# 复制此文件为 .env 并填入实际值
# cp env.example .env
# ============================================================================

# ---- TURN Server ----
# coturn 用户名（建议使用复杂用户名，避免撞库）
TURN_USERNAME=localsend_user

# coturn 密码（建议 16 位以上随机字符串）
TURN_PASSWORD=change_me_to_a_secure_password

# ---- Signaling Server ----
# 信令服务器监听端口
SIGNALING_PORT=9000

# Rust 日志级别 (trace, debug, info, warn, error)
RUST_LOG=info

# ---- Remote Deployment ----
# 远程服务器 IP 或域名
REMOTE_HOST=101.132.143.168

# SSH 登录用户
REMOTE_USER=root

# 远程部署路径
REMOTE_PATH=/opt/localsend-server

# SSH 私钥路径（留空则使用默认 SSH agent）
SSH_KEY=
